# ── LLM Configuration ──
# Get your token from https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Model to use (must be ≤ 16B open-weights)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Backend: "huggingface" (API) or "mock" (for demo/testing)
LLM_BACKEND=huggingface

# ── Scoring ──
FACET_BATCH_SIZE=10
MAX_NEW_TOKENS=2048
TEMPERATURE=0.3

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
